# Copy this file to .env and fill in your values
# docker compose will pick it up automatically

# Required — your OpenRouter API key
OPENROUTER_API_KEY=sk-or-...

# Optional — override the model used for evaluation (any OpenRouter model string)
# Default: anthropic/claude-sonnet-4-5
# See available models at https://openrouter.ai/models
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Optional — override database connection
# Default: postgresql://postgres:postgres@postgres:5432/career_ops
# DATABASE_URL=postgresql://...

# Optional — override Redis connection
# Default: redis://redis:6379
# REDIS_URL=redis://redis:6379

# Optional — override backend port
# Default: 5001
# BACKEND_PORT=5001

# Optional — override the API URL used by the web frontend
# Default: http://localhost:5001
# NEXT_PUBLIC_API_URL=http://localhost:5001
